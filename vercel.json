{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    {
      "source": "/install.sh",
      "destination": "https://raw.githubusercontent.com/archcore-ai/cli/refs/heads/main/install.sh",
      "statusCode": 302
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
