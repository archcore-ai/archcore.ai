msgid "Then ask the agent to link them: <0>add_relation(rule implements adr)</0>, <1>add_relation(guide related rule)</1>."
msgstr "После — попросите агента связать их: <0>add_relation(rule implements adr)</0>, <1>add_relation(guide related rule)</1>."

