#: src/components/cta/team-setup-dialog.tsx:116
#: src/pages/teams-getting-started.tsx:155
msgid "After launch, open <0>http://localhost</0> in your browser."
msgstr "После запуска откройте <0>http://localhost</0> в браузере."

#: src/components/sections/how-we-solve-section.tsx:45
msgid "Any compliant agent queries .archcore/ on demand or auto-loads it before edits."
msgstr "Любой совместимый агент обращается к .archcore/ по запросу или подгружает контекст перед правками."

#: src/pages/cli.tsx:18
msgid "Archcore CLI — repo memory for every AI coding agent"
msgstr "Archcore CLI — память репозитория для любого AI-агента разработки"

#: src/pages/cli.tsx:20
msgid "Archcore CLI creates .archcore/, wires MCP and hooks, and lets agents read and write decisions, rules, plans, and guides from Git."
msgstr "Archcore CLI создаёт .archcore/, подключает MCP и хуки и позволяет агентам читать и записывать решения, правила, планы и гайды прямо из Git."

#: src/components/sections/cli-hero-section.tsx:27
msgid "Archcore CLI creates <0>.archcore/</0>, wires MCP and hooks, and lets your agents read and write decisions, rules, plans, and guides from Git."
msgstr "Archcore CLI создаёт <0>.archcore/</0>, настраивает MCP и хуки и позволяет агентам читать и записывать решения, правила, планы и гайды прямо из Git."

#: src/components/sections/cli-showcase-section.tsx:18
msgid "archcore init creating .archcore/ in a project"
msgstr "archcore init создаёт .archcore/ в проекте"

#: src/pages/plugin.tsx:19
msgid "Archcore Plugin — repo context for Claude Code, Cursor & Codex CLI"
msgstr "Archcore Plugin — контекст репозитория для Claude Code, Cursor и Codex CLI"

#: src/components/sections/plugin-showcase-section.tsx:46
msgid "Archcore plugin in the Cursor plugin marketplace, showing MCP and slash commands"
msgstr "Плагин Archcore в маркетплейсе плагинов Cursor с MCP и slash-командами"

#: src/components/sections/hero-section.tsx:64
msgid "Archcore turns your repository into structured, machine-readable context — so Claude Code, Cursor, and other AI agents follow your architecture, rules, and decisions instead of guessing."
msgstr "Archcore превращает репозиторий в структурированный машиночитаемый контекст — чтобы Claude Code, Cursor и другие AI-агенты следовали вашей архитектуре, правилам и решениям, а не угадывали их."

#: src/components/sections/plugin-pillars-section.tsx:45
#~ msgid "Auto-bundles a launcher that resolves the Archcore CLI on first call. MCP registers itself."
#~ msgstr "Включает встроенный лаунчер, который сам подтягивает Archcore CLI при первом вызове. MCP регистрируется автоматически."

